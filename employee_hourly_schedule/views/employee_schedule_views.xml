<?xml version="1.0" encoding="UTF-8"?>
<!--
    Planeación Operativa - Employee Hourly Schedule Views
    
    Vistas para gestión de planificación operativa:
    - Vista de calendario con colores por estado
    - Vistas de lista, formulario y pivot
    - Búsquedas y filtros personalizados
    - Menús integrados en Recursos Humanos
    
    @module employee_hourly_schedule
    @version 17.0.1.0.1
    @license LGPL-3
-->
<odoo>
    <record id="view_employee_hourly_schedule_tree" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.list</field>
        <field name="model">x_employee_hourly_schedule</field>
        <field name="arch" type="xml">
            <tree string="Planes Diarios" 
                  decoration-info="date == context_today()" 
                  decoration-muted="date &lt; context_today()"
                  decoration-bf="is_recurrent">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="date"/>
                <field name="is_recurrent" widget="boolean" string="🔁 Recurrente"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_employee_hourly_schedule_form" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.form</field>
        <field name="model">x_employee_hourly_schedule</field>
        <field name="arch" type="xml">
            <form string="Planeación Operativa por Horas">
                <header>
                    <button name="action_duplicate_to_next_week" 
                            string="📅 Duplicar a Próxima Semana" 
                            type="object" 
                            class="btn-primary"
                            help="Copia este horario automáticamente a la próxima semana"/>
                    <button name="action_duplicate_to_multiple_weeks" 
                            string="📆 Duplicar a Varias Semanas" 
                            type="object" 
                            class="btn-secondary"
                            help="Copia este horario a múltiples semanas futuras"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_done" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-check-circle">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Marcar Todo</span>
                                <span class="o_stat_text">Completado</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Plantilla Recurrente" bg_color="bg-success" invisible="not is_recurrent"/>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="is_recurrent" widget="boolean_toggle" 
                                   help="Marcar para duplicar automáticamente cada semana"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="📋 Horas del Día" name="hours">
                            <field name="line_ids" context="{'default_schedule_id': id}">
                                <tree editable="bottom" 
                                      decoration-success="is_done and state == 'done'" 
                                      decoration-info="state == 'in_progress'" 
                                      decoration-warning="state == 'pending' and not is_overloaded" 
                                      decoration-danger="is_overloaded"
                                      decoration-bf="is_overloaded or state == 'in_progress'">
                                                                        <button name="%(action_duplicate_assigned_task_line)d"
                                                                                        type="action"
                                                                                        icon="fa-copy"
                                                                                        string="Duplicar"
                                                                                                                            class="btn-link"/>
                                    <field name="activity_name"/>
                                    <field name="start_datetime"/>
                                    <field name="end_datetime"/>
                                    <field name="duration_hours" sum="Total Horas"/>
                                    <field name="project_id"/>
                                    <field name="task_id"/>
                                    <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state == 'in_progress'" decoration-warning="state == 'pending'"/>
                                    <field name="is_done" widget="boolean_toggle"/>
                                    <field name="is_overloaded" invisible="1"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_hourly_schedule_search" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.search</field>
        <field name="model">x_employee_hourly_schedule</field>
        <field name="arch" type="xml">
            <search string="Buscar Planeación">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="date"/>
            </search>
        </field>
    </record>

    <record id="view_employee_hourly_schedule_line_list" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.line.list</field>
        <field name="model">x_employee_hourly_schedule_line</field>
        <field name="arch" type="xml">
            <tree string="Actividades" 
                  decoration-success="is_done and state == 'done'" 
                  decoration-info="state == 'in_progress' and not is_overloaded" 
                  decoration-warning="state == 'pending' and not is_overloaded" 
                  decoration-danger="is_overloaded"
                  decoration-bf="is_overloaded or state == 'in_progress'"
                  decoration-muted="is_done and state == 'done'">
                                <button name="%(action_duplicate_assigned_task_line)d"
                                                type="action"
                                                icon="fa-copy"
                                                string="Duplicar"
                                                class="btn-link"/>
                <field name="schedule_id" invisible="1"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="date"/>
                <field name="activity_name"/>
                <field name="time_range"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="duration_hours" sum="Total Horas"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state == 'in_progress'" decoration-warning="state == 'pending'"/>
                <field name="is_done" widget="boolean_toggle"/>
                <field name="is_overloaded" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_employee_hourly_schedule_line_form" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.line.form</field>
        <field name="model">x_employee_hourly_schedule_line</field>
        <field name="arch" type="xml">
            <form string="Actividad de Planeación">
                <header>
                    <button name="%(action_duplicate_assigned_task_line)d"
                            string="🔁 Duplicar Tarea"
                            type="action"
                            class="btn-primary"
                            help="Duplica esta actividad."/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_done" type="object" class="oe_stat_button" icon="fa-check-circle" invisible="is_done">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Marcar</span>
                                <span class="o_stat_text">Hecho</span>
                            </div>
                        </button>
                        <button name="toggle_done" type="object" class="oe_stat_button" icon="fa-check-circle" style="color: green;" invisible="not is_done">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text" style="color: green;">✓ Completado</span>
                            </div>
                        </button>
                        <button name="action_attachment_open" type="object" class="oe_stat_button" icon="fa-image">
                            <field name="attachment_count" widget="statinfo" string="Fotos"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="activity_name" placeholder="Nombre de la actividad..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="📋 Información General">
                            <field name="schedule_id"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="date"/>
                        </group>
                        <group string="⏰ Horarios">
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="duration_hours" readonly="1" widget="float_time"/>
                            <field name="daily_total_hours" readonly="1" widget="float_time"/>
                            <field name="is_overloaded" readonly="1" widget="boolean"/>
                        </group>
                    </group>
                    <group>
                        <group string="🎯 Proyecto y Tarea">
                            <field name="project_id"/>
                            <field name="task_id" domain="[('project_id', '=', project_id)]"/>
                        </group>
                        <group string="✅ Estado">
                            <field name="is_done" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group>
                        <group string="📸 Foto Principal de la Actividad">
                            <field name="activity_photo" widget="image" nolabel="1"/>
                        </group>
                    </group>
                    <group string="📝 Notas y Observaciones">
                        <field name="note" nolabel="1" placeholder="Agrega notas, descripciones o comentarios sobre esta actividad..."/>
                    </group>
                    <separator/>
                    <p class="oe_inline" style="color: gray; font-size: small;">
                        💡 Consejo: Puedes agregar más fotos desde el botón de 📷 Fotos en la parte superior.
                    </p>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_hourly_schedule_line_calendar" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.line.calendar</field>
        <field name="model">x_employee_hourly_schedule_line</field>
        <field name="arch" type="xml">
            <calendar string="Calendario" date_start="start_datetime" date_stop="end_datetime" color="calendar_color" mode="month" event_open_popup="true">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="activity_name"/>
                <field name="state"/>
                <field name="is_done"/>
                <field name="duration_hours"/>
            </calendar>
        </field>
    </record>


    <record id="view_employee_hourly_schedule_line_pivot" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.line.pivot</field>
        <field name="model">x_employee_hourly_schedule_line</field>
        <field name="arch" type="xml">
            <pivot string="Análisis">
                <field name="employee_id" type="row"/>
                <field name="date" type="col"/>
                <field name="duration_hours" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_employee_hourly_schedule_line_search" model="ir.ui.view">
        <field name="name">employee.hourly.schedule.line.search</field>
        <field name="model">x_employee_hourly_schedule_line</field>
        <field name="arch" type="xml">
            <search string="Buscar Actividades">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="state"/>
                <field name="is_done"/>
                <field name="is_overloaded"/>
                <separator/>
                <filter name="pending" string="⏳ Pendiente" domain="[('state', '=', 'pending')]"/>
                <filter name="in_progress" string="🔄 En Progreso" domain="[('state', '=', 'in_progress')]"/>
                <filter name="done" string="✅ Completado" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="today" string="📅 Hoy" domain="[('date', '=', context_today())]"/>
                <filter name="this_week" string="📆 Esta Semana" domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday()))), ('date', '&lt;=', (context_today() + relativedelta(days=6-context_today().weekday())))]"/>
                <separator/>
                <filter name="dept_admin" string="👔 Administración" domain="[('department_id.name', 'ilike', 'Admin')]"/>
                <filter name="dept_sales" string="💼 Ventas" domain="[('department_id.name', 'ilike', 'Venta')]"/>
                <filter name="dept_warehouse" string="📦 Bodega" domain="[('department_id.name', 'ilike', 'Bodega')]"/>
                <filter name="dept_purchases" string="🛒 Compras" domain="[('department_id.name', 'ilike', 'Compra')]"/>
                <filter name="dept_management" string="🎯 Gerencia" domain="[('department_id.name', 'ilike', 'Gerenc')]"/>
                <separator/>
                <filter name="overloaded" string="⚠️ Sobrecarga" domain="[('is_overloaded', '=', True)]"/>
                <separator/>
                <group expand="0" string="Agrupar Por">
                    <filter name="group_by_employee" string="Empleado" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_by_department" string="Departamento" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_by_date" string="Fecha" context="{'group_by': 'date'}"/>
                    <filter name="group_by_project" string="Proyecto" context="{'group_by': 'project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_employee_hourly_schedule" model="ir.actions.act_window">
        <field name="name">Planeación Operativa</field>
        <field name="res_model">x_employee_hourly_schedule</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_employee_hourly_schedule_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea el primer plan horario para un empleado.
            </p>
        </field>
    </record>

    <record id="action_employee_hourly_schedule_line" model="ir.actions.act_window">
        <field name="name">Agenda Operativa</field>
        <field name="res_model">x_employee_hourly_schedule_line</field>
        <field name="view_mode">calendar,tree,form,pivot</field>
        <field name="search_view_id" ref="view_employee_hourly_schedule_line_search"/>
    </record>

    <record id="action_employee_hourly_schedule_line_my_pending" model="ir.actions.act_window">
        <field name="name">Mis Tareas</field>
        <field name="res_model">x_employee_hourly_schedule_line</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_employee_hourly_schedule_line_search"/>
        <field name="domain">[("employee_id.user_id", "=", uid)]</field>
    </record>

    <record id="action_employee_hourly_schedule_report" model="ir.actions.act_window">
        <field name="name">Reporte por Empleado</field>
        <field name="res_model">x_employee_hourly_schedule_line</field>
        <field name="view_mode">pivot,tree</field>
        <field name="search_view_id" ref="view_employee_hourly_schedule_line_search"/>
        <field name="context">{"search_default_group_by_employee_id": 1}</field>
    </record>

    <menuitem id="menu_employee_hourly_schedule_root"
              name="Planeacion Operativa"
              parent="hr.menu_hr_root"
              groups="hr.group_hr_user,hr.group_hr_manager"
              sequence="60"/>
    
    <!-- Nivel 3: Solo "Mis Tareas" - Menú básico para empleados -->
    <menuitem id="menu_employee_hourly_schedule_my_pending"
              name="✅ Mis Tareas"
              parent="menu_employee_hourly_schedule_root"
              action="action_employee_hourly_schedule_line_my_pending"
              groups="hr.group_hr_user,hr.group_hr_manager"
              sequence="5"/>
    
    <!-- Nivel 2: Planeación Operativa Completa - Menús de gestión -->
    <menuitem id="menu_employee_hourly_schedule"
              name="📅 Planes por Dia"
              parent="menu_employee_hourly_schedule_root"
              action="action_employee_hourly_schedule"
              groups="hr.group_hr_user,hr.group_hr_manager"
              sequence="10"/>
    
    <menuitem id="menu_employee_hourly_schedule_calendar"
              name="📊 Agenda Operativa"
              parent="menu_employee_hourly_schedule_root"
              action="action_employee_hourly_schedule_line"
              groups="hr.group_hr_user,hr.group_hr_manager"
              sequence="20"/>
    
    <menuitem id="menu_employee_hourly_schedule_report"
              name="📈 Reporte por Empleado"
              parent="menu_employee_hourly_schedule_root"
              action="action_employee_hourly_schedule_report"
              groups="hr.group_hr_user,hr.group_hr_manager"
              sequence="30"/>

</odoo>
